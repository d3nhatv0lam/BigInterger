<rxui:ReactiveUserControl x:TypeArguments="vm:CalculatorViewModel"
                          xmlns="https://github.com/avaloniaui"
                          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                          mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
                          xmlns:vm="clr-namespace:Bignum.ViewModels"
                          xmlns:rxui="http://reactiveui.net"
                          xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
                          x:DataType="vm:CalculatorViewModel"
                          x:CompileBindings="True"
                          Focusable="True"
                          x:Name="RootControl"
                          x:Class="Bignum.Views.CalculatorView">


    <Interaction.Behaviors>
        <AdaptiveBehavior SourceControl="{Binding #RootControl}">
            <AdaptiveClassSetter MinWidth="0" MaxWidth="650" ClassName="mobile" />
        </AdaptiveBehavior>
    </Interaction.Behaviors>

    <rxui:ReactiveUserControl.Styles>
        <Style Selector=".input-field">
            <Style Selector="^ Label">
                <Setter Property="FontWeight" Value="Bold"></Setter>
                <Setter Property="FontSize" Value="16"></Setter>
            </Style>
        </Style>

        <!-- Responsive visibility states -->
        <Style Selector="Grid.desktop-only">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="StackPanel.mobile-only">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector=":is(UserControl).mobile Grid.desktop-only">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector=":is(UserControl).mobile StackPanel.mobile-only">
            <Setter Property="IsVisible" Value="True" />
        </Style>
    </rxui:ReactiveUserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Border Padding="16" Background="Transparent" PointerPressed="Background_OnPointerPressed">
            <Grid RowDefinitions="auto auto auto auto auto" RowSpacing="20">
                <!-- // số A // -->
                <StackPanel Grid.Row="0" Classes="input-field">
                    <Grid ColumnDefinitions="* Auto" Margin="0,0,0,4">
                        <Label Grid.Column="0" Target="NumberA" FontWeight="Bold" FontSize="16" VerticalAlignment="Center">Số A</Label>
                        <Button Grid.Column="1"
                                IsTabStop="False"
                                Command="{Binding ClearNumberACommand}"
                                Classes="flat" Padding="4" Background="Transparent" BorderThickness="0" Width="32"
                                Height="32">
                            <icons:MaterialIcon Kind="Close" Width="18" Height="18" Foreground="Black" />
                        </Button>
                    </Grid>

                    <TextBox x:Name="NumberA" UseFloatingPlaceholder="False"
                             MaxLength="{Binding InputMaxLength}"
                             Classes="outline"
                             Theme="{StaticResource OutlineTextBox}"
                             Text="{Binding NumberA, Mode=TwoWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             PlaceholderText="Nhập số A" />

                    <Grid ColumnDefinitions="* Auto" Margin="4,4,4,0">
                        <TextBlock x:Name="NumberAErrorText"
                                   Grid.Column="0"
                                   Foreground="#D32F2F"
                                   FontSize="12"
                                   IsVisible="{Binding ElementName=NumberAErrorText, Path=Text, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding NumberADigitCountDisplay}"
                                   Foreground="#757575"
                                   FontSize="12"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>

                <!-- // Số B // -->
                <StackPanel Grid.Row="1" Classes="input-field">
                    <Grid ColumnDefinitions="* Auto" Margin="0,0,0,4">
                        <Label Grid.Column="0" Target="NumberB" FontWeight="Bold" FontSize="16" VerticalAlignment="Center">Số B</Label>
                        <Button Grid.Column="1"
                                IsTabStop="False"
                                Command="{Binding ClearNumberBCommand}"
                                Classes="flat" Padding="4" Background="Transparent" BorderThickness="0" Width="32"
                                Height="32">
                            <icons:MaterialIcon Kind="Close" Width="18" Height="18" Foreground="Black" />
                        </Button>
                    </Grid>

                    <TextBox x:Name="NumberB" UseFloatingPlaceholder="False"
                             MaxLength="{Binding InputMaxLength}"
                             Classes="outline"
                             Theme="{StaticResource OutlineTextBox}"
                             Text="{Binding NumberB, Mode=TwoWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             PlaceholderText="Nhập số B" />

                    <Grid ColumnDefinitions="* Auto" Margin="4,4,4,0">
                        <TextBlock x:Name="NumberBErrorText"
                                   Grid.Column="0"
                                   Foreground="#D32F2F"
                                   FontSize="12"
                                   IsVisible="{Binding ElementName=NumberBErrorText, Path=Text, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding NumberBDigitCountDisplay}"
                                   Foreground="#757575"
                                   FontSize="12"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>

                <!-- // phép toán  -->
                <Border BorderThickness="1" BorderBrush="#EAE2F0" Grid.Row="2" CornerRadius="10">
                    <Border Padding="10">
                        <Panel>
                            <!-- // desktop // -->
                            <Grid Classes="desktop-only" ColumnDefinitions="Auto * Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Phép toán"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold" />

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                                            Margin="16,0">
                                    <StackPanel.Styles>
                                        <Style Selector="Button.op-btn">
                                            <Setter Property="CornerRadius" Value="16" />
                                            <Setter Property="Padding" Value="14 6" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="Background" Value="#EAE2F0" />
                                            <Setter Property="Foreground" Value="#4C4452" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                        <Style Selector="Button.op-btn[Tag=True]">
                                            <Setter Property="Background" Value="#4C4452" />
                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                        </Style>
                                    </StackPanel.Styles>

                                    <Button Classes="op-btn" Content="Phép cộng (+)"
                                            Command="{Binding SelectOperationCommand}"
                                            CommandParameter="{x:Static vm:OperationType.Add}"
                                            Tag="{Binding IsAddActive}" />

                                    <Button Classes="op-btn" Content="Phép trừ (-)"
                                            Command="{Binding SelectOperationCommand}"
                                            CommandParameter="{x:Static vm:OperationType.Subtract}"
                                            Tag="{Binding IsSubtractActive}" />

                                    <Button Classes="op-btn" Content="Phép nhân (x)"
                                            Command="{Binding SelectOperationCommand}"
                                            CommandParameter="{x:Static vm:OperationType.Multiply}"
                                            Tag="{Binding IsMultiplyActive}" />

                                    <Button Classes="op-btn" Content="Phép chia (/)"
                                            Command="{Binding SelectOperationCommand}"
                                            CommandParameter="{x:Static vm:OperationType.Divide}"
                                            Tag="{Binding IsDivideActive}" />
                                </StackPanel>

                                <Button
                                    Grid.Column="2"
                                    Command="{Binding ClearResultCommand}"
                                    Content="Xóa kết quả"
                                    Background="#C62828"
                                    Foreground="White"
                                    CornerRadius="8"
                                    Padding="16, 8"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold" />
                            </Grid>

                            <!-- // Mobile // -->
                            <StackPanel Classes="mobile-only" Spacing="12">
                                <TextBlock Text="Phép toán" FontWeight="Bold" />

                                <UniformGrid Columns="2" Rows="2">
                                    <UniformGrid.Styles>
                                        <Style Selector="Button.op-btn-mob">
                                            <Setter Property="CornerRadius" Value="16" />
                                            <Setter Property="Padding" Value="14 10" />
                                            <Setter Property="Margin" Value="4" />
                                            <Setter Property="FontSize" Value="14" />
                                            <Setter Property="Background" Value="#EAE2F0" />
                                            <Setter Property="Foreground" Value="#4C4452" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        </Style>
                                        <Style Selector="Button.op-btn-mob[Tag=True]">
                                            <Setter Property="Background" Value="#4C4452" />
                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                        </Style>
                                    </UniformGrid.Styles>

                                    <Button Classes="op-btn-mob" Content="Cộng (+)"
                                            Command="{Binding SelectOperationCommand}"
                                            CommandParameter="{x:Static vm:OperationType.Add}"
                                            Tag="{Binding IsAddActive}" />

                                    <Button Classes="op-btn-mob" Content="Trừ (-)"
                                            Command="{Binding SelectOperationCommand}"
                                            CommandParameter="{x:Static vm:OperationType.Subtract}"
                                            Tag="{Binding IsSubtractActive}" />

                                    <Button Classes="op-btn-mob" Content="Nhân (x)"
                                            Command="{Binding SelectOperationCommand}"
                                            CommandParameter="{x:Static vm:OperationType.Multiply}"
                                            Tag="{Binding IsMultiplyActive}" />

                                    <Button Classes="op-btn-mob" Content="Chia (/)"
                                            Command="{Binding SelectOperationCommand}"
                                            CommandParameter="{x:Static vm:OperationType.Divide}"
                                            Tag="{Binding IsDivideActive}" />
                                </UniformGrid>

                                <Button
                                    Command="{Binding ClearResultCommand}"
                                    Content="Xóa kết quả"
                                    Background="#C62828"
                                    Foreground="White"
                                    CornerRadius="8"
                                    Padding="16, 12"
                                    Margin="4,4,4,0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    FontWeight="Bold" />
                            </StackPanel>
                        </Panel>
                    </Border>
                </Border>

                <!-- // Kết quả // -->
                <StackPanel Grid.Row="3" Classes="input-field">
                    <Label Target="Result">Kết quả</Label>
                    <TextBox x:Name="Result" UseFloatingPlaceholder="False"
                             IsReadOnly="True"
                             Classes="outline"
                             Theme="{StaticResource OutlineTextBox}"
                             Text="{Binding ResultString, Mode=OneWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             PlaceholderText="0" />
                </StackPanel>

                <!-- // Số dư // -->
                <StackPanel Grid.Row="4" Classes="input-field">
                    <Label Target="Remainder">Số dư</Label>
                    <TextBox x:Name="Remainder" UseFloatingPlaceholder="False"
                             Classes="outline"
                             IsReadOnly="True"
                             Theme="{StaticResource OutlineTextBox}"
                             Text="{Binding RemainderString, Mode=OneWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             PlaceholderText="0" />
                </StackPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</rxui:ReactiveUserControl>