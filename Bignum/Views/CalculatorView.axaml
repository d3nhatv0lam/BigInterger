<rxui:ReactiveUserControl x:TypeArguments="vm:CalculatorViewModel"
                          xmlns="https://github.com/avaloniaui"
                          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                          mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                          xmlns:vm="clr-namespace:Bignum.ViewModels"
                          xmlns:rxui="http://reactiveui.net"
                          x:DataType="vm:CalculatorViewModel"
                          x:CompileBindings="True"
                          x:Class="Bignum.Views.CalculatorView">
    <Border>
        <TextBlock Text="CALCULATORRRRRRRRR" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
    </Border>
</rxui:ReactiveUserControl>
